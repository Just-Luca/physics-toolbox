#include <cstdlib>

using namespace std;

void MinMax (int* data, int dim, int& min, int& max){
  min = max = data[0];
  for (int i = 0; i < dim; i++){
    if (data[i] < min){
      min = data[i];
    }
    if (data[i] > max){
      max = data [i];
    }
  }
}

double rand_range(double min, double max){
  return min + (max-min) * rand() /(1. * RAND_MAX);
}

