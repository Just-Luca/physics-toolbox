#include <iostream>
#include <fstream>

#include "funzioni.h"

#include <cstdlib>

#include <TH1D.h>
#include <TF1.h>
#include <TCanvas.h>
#include <TApplication.h>
#include <TStyle.h>

using namespace std;

int main (){

  //Istanzio la TApplication per visualizzare l'istogramma, il TCAnvas, e
  //l'istogramma stesso.
  gStyle -> SetOptFit(1112); //codice per visualizzare tutti i parametri
  TApplication* TApp   = new TApplication ("TApp", NULL, NULL);
  TCanvas* 	Canv   = new TCanvas ("CanvA", "distribuzioni", 0,0,700,500);
  TH1D* 	Histo = new TH1D ("Histo", "Energy distribution", 1000, 0, 10);


  //apro il file richiesto
  ifstream infile ("energy_distr.txt");

  //controllo che l'apertura del file sia andata a buon fine e istanzio le
  //variabli che servono per leggere i dati del file. Leggo il file e inserisco
  //direttamente i dati nell'istogramma
  double x;
  
  if (! infile.good()){
    cout << "ERRORE: impossibile aprire il file energy_distr.txt" << endl;
    return 1;
  } else {
    while (true){ //imposto un ciclo per leggere il file fino a EOF
      infile >> x;
      if (infile.eof()) break;
      Histo -> Fill(x); //inserisco di volta in volta il dato nell'istogramma
    }
  }

  //definisco tre TF1 per i fit dell'istogramma e le inizializzo
  TF1* f1 = new TF1 ("f1", fun1, 0, 10, 1);
  f1 -> SetParameter (0, 1000);
  f1 -> SetParName   (0, "par0");

  TF1* f2 = new TF1 ("f2", fun2, 0, 10, 2);
  f2 -> SetParameter (0, 2000);
  f2 -> SetParameter (1, 1);
  f2 -> SetParName   (0, "par0");
  f2 -> SetParName   (1, "par1");

  TF1* f3 = new TF1 ("f3", fun3, 0, 10, 3);
  f3 -> SetParameter (0, 2.67e+08);
  f3 -> SetParameter (1, 35.11);
  f3 -> SetParameter (2, 7.179);
  f3 -> SetParName   (0, "par0");
  f3 -> SetParName   (1, "par1");
  f3 -> SetParName   (2, "par2");
  
  Histo -> Fit("f1");
  Histo -> Fit("f2", "+");
  Histo -> Fit("f3", "+") ;
  
  Canv   ->cd();

  Histo -> Draw();
  f3 -> Draw("same");

  Canv   -> Modified();
  Canv   -> Update();

  TApp -> Run();

}
